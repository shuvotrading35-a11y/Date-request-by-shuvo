# ============================================
# DATE REQUEST PLATFORM — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=https://date-request-by-shuvo.onrender.com

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"
# PostgreSQL example:
# DATABASE_URL="postgresql://postgres:rpTMfSiaZNweJclwcGaxPduSXMUzRmKa@postgres.railway.internal:5432/railway"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_RESET_EXPIRY=1h

# Bcrypt
BCRYPT_ROUNDS=12

# Admin credentials (first admin account)
ADMIN_EMAIL=shuvofc269@gmail.com
ADMIN_PASSWORD=Admin@123456
ADMIN_USERNAME=superadmin

# Telegram Bot (Admin notifications)
TELEGRAM_BOT_TOKEN=8619015756:AAGqrwcK_HzOo1xXeVmxmJSHQSBgRcZdVDo
TELEGRAM_CHAT_ID=-1003810030643

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="DateRequest 💌 <noreply@yourdomain.com>"

# Discord Webhook (Admin alerts)
DISCORD_WEBHOOK_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_API_MAX=100
RATE_LIMIT_PUBLIC_MAX=30

# Token
SHARE_TOKEN_LENGTH=10

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Cookie
COOKIE_SECRET=your_cookie_secret_change_this
